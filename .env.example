PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://shlokgoyal:<washedchamber>@kinu-cafe-cluster.wpnovii.mongodb.net/kinu_cafe?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Default admin (seeded on boot if missing)
DEFAULT_ADMIN_EMAIL=admin@kinucafe.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Kinu Admin

# Frontend base URL — used when building QR URLs for tables
FRONTEND_URL=http://localhost:3000

# Billing defaults (used when Settings singleton is absent)
TAX_RATE=0.05
BIRTHDAY_DISCOUNT_PERCENT=10

# OTP / SMS
SMS_PROVIDER=dev
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5

# Twilio (optional, only if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# MSG91 (optional, only if SMS_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
